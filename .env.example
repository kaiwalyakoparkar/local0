# local0 — config. Copy to `.env` and adjust.

# --- Ollama (host process, reused; not containerized) ---
# Router runs in a container → reach host Ollama via host.docker.internal.
# Running the router natively? use http://localhost:11434
OLLAMA_URL=http://host.docker.internal:11434
GEN_MODEL=qwen3:0.6b
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768

# --- Qdrant ---
QDRANT_URL=http://vectordb:6333
COLLECTION=docs

# --- Gate ---
# Escalate (HTTP 424) when retrieval top_score < THRESHOLD.
# 0.55 is a pre-eval guess. Phase 6 eval.py replaces it with a measured value.
THRESHOLD=0.55

# --- Dashboard cost estimate (display only) ---
# Gross cloud spend avoided per locally-answered call. Not a net-savings figure.
CLOUD_USD_PER_CALL=0.01

# --- Docs to ingest ---
DOCS_DIR=./docs

# --- Learn callback (POST /learn from gateway after 424→cloud) ---
# Comma-separated substrings; query must contain one or the Q&A is skipped.
# Empty = store nothing. Seed/demo payloads use "gravitee".
LEARN_TAGS=gravitee

# --- Control-plane auth & limits ---
# ADMIN_TOKEN: when set, /config, /stats/reset, /gateway/* and /demo require an
#   X-Admin-Token header. Unset = local-only Host check (spoofable; dev only).
#   Set this for ANY non-local deployment.
# LEARN_TOKEN: when set, POST /learn requires an X-Learn-Token header (gateway
#   callout policy injects it). Blocks unauthenticated cache poisoning.
# MAX_BODY_BYTES: reject requests larger than this (bounds prompt-size DoS).
# LOG_LEVEL: DEBUG|INFO|WARNING|ERROR.
ADMIN_TOKEN=
LEARN_TOKEN=
MAX_BODY_BYTES=65536
LOG_LEVEL=INFO
